---
import type { Post } from '@/types/post';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const formattedDate = new Date(post.createdAt).toISOString().split('T')[0];
---

<article class="group cursor-pointer mb-stack-md">
  <a href={`/posts/${post.slug}`} class="block">
    <h2 class="font-headline-md text-headline-md text-primary mb-1 group-hover:text-secondary transition-colors">
      {post.title}
    </h2>
    <div class="flex items-center gap-2 font-meta-italic text-meta-italic text-secondary mb-2">
      <time datetime={formattedDate}>{formattedDate}</time>
      {post.category && (
        <>
          <span class="text-border-subtle px-1">•</span>
          <span>{post.category}</span>
        </>
      )}
    </div>
    <p class="font-body-md text-body-md text-on-surface-variant line-clamp-2">
      {post.excerpt}
    </p>
  </a>
</article>
