---
/**
 * Renders the social-media links a user has filled in, as brand-icon buttons.
 * Only platforms with a non-empty value are shown.
 */
interface Props {
  social?: Record<string, string | null | undefined> | null;
  class?: string;
  size?: number;
}
const { social, class: className = '', size = 18 } = Astro.props;

// simple-icons style single-path glyphs (viewBox 0 0 24 24, fill currentColor).
