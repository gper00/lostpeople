const order = ['twitter', 'instagram', 'facebook', 'telegram', 'whatsapp'];
const present = order
  .filter((k) => social && social[k])
  .map((k) => ({ key: k, url: social![k] as string, ...ICONS[k] }));
---

{present.length > 0 && (
  <div class={`flex items-center gap-2 ${className}`}>
    {present.map((s) => (
      <a
        href={s.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={s.label}
        title={s.label}
        class="inline-flex items-center justify-center w-9 h-9 border border-border-subtle text-secondary hover:text-primary hover:border-primary transition-colors rounded-full no-underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d={s.path} />
        </svg>
      </a>
    ))}
  </div>
)}
