---
const navLinks = [
  { href: '/', label: 'Posts' },
  { href: '/tags', label: 'Tags' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<aside class="hidden lg:flex flex-col h-screen sticky top-0 w-[14rem] shrink-0 bg-background z-10">
  <div class="pt-16">
    <a class="font-brand text-[2.5rem] font-bold leading-tight text-primary block mb-1" href="/">
      Lostpeople
    </a>
    <p class="font-meta-italic text-meta-italic italic text-secondary">
      Revive the beauty of typography
    </p>
  </div>

  <div class="flex-1 flex flex-col items-start justify-center gap-4">
    <nav class="flex flex-col gap-3 items-start">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-secondary font-headline-md text-headline-md italic highlight-hover transition-colors hover:text-primary',
            currentPath === href
              ? 'highlight-static text-primary font-medium'
              : '',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4 text-secondary">
      <a
        href="/search"
        class="hover:text-primary transition-colors"
        aria-label="Search"
      >
        <span class="material-symbols-outlined text-[18px] leading-none">search</span>
      </a>
      <button
        id="font-size-toggle"
        class="hover:text-primary cursor-pointer transition-colors font-body-md text-[18px] leading-none"
        aria-label="Toggle font size"
      >
        A
      </button>
      <button
        id="theme-toggle"
        class="hover:text-primary cursor-pointer transition-colors font-body-md text-[18px] leading-none"
        aria-label="Toggle theme"
      >
        O
      </button>
    </div>
  </div>

  <div class="mt-auto pb-10">
    <p class="font-label-sm text-label-sm text-secondary mb-1">
      RSS / GitHub / Email
    </p>
    <p class="font-label-sm text-label-sm text-secondary italic">
      © 2025-2026 Lostpeople.<br />
      Powered by Astro and Retypeset.
    </p>
  </div>
</aside>

<script>
  // Re-bind after every view transition (ClientRouter doesn't re-run module scripts)
  function initThemeToggle() {
    const themeToggle = document.getElementById('theme-toggle');
    themeToggle?.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.classList.toggle('dark');
      document.cookie = `theme=${isDark ? 'dark' : 'light'}; path=/; max-age=31536000`;
    });
  }
  document.addEventListener('astro:page-load', initThemeToggle);
</script>
