---
export const prerender = true;

import ListLayout from '@/layouts/ListLayout.astro';
import SocialLinks from '@/components/shared/SocialLinks.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';
import User from '@/models/User';

try {
  await connectDB();
} catch (e) {
  console.warn('Could not connect to database during build:', e);
}

let authors: any[] = [];

try {
  const authorIds = await Post.distinct('userId', { status: 'published' });
  const users = await User.find({ _id: { $in: authorIds } }).lean();
  authors = JSON.parse(JSON.stringify(users));
} catch (e) {
  console.warn('Could not fetch authors during build:', e);
}
---

<ListLayout title="About | Lostpeople" description="Tentang Lostpeople">
  <article>
    <header class="mb-8">
      <h1 class="font-display text-3xl text-ink mb-2">
        About
      </h1>
      <div class="w-full h-px bg-dust"></div>
    </header>

    <div class="prose prose-lg">
      <p class="drop-cap">
        Lostpeople adalah blog inspiratif yang menyajikan cerita, tips, dan informasi
        seputar kehidupan serta teknologi.
      </p>

      <p>
        Dibuat oleh <strong>Umam Alfarizi</strong> dengan tujuan berbagi pengetahuan
        dan pengalaman dalam perjalanan hidup dan dunia teknologi.
      </p>

      <h2>Kontak</h2>
      <ul>
        <li><a href="https://github.com/gper00" target="_blank">GitHub</a></li>
        <li><a href="https://linkedin.com/in/umam-alfarizi" target="_blank">LinkedIn</a></li>
        <li><a href="https://twitter.com/gper00" target="_blank">Twitter</a></li>
      </ul>
    </div>

    <!-- Tim Kami -->
    <section class="mt-10">
      <div class="w-full h-px bg-dust mb-6"></div>
      <h2 class="font-display text-xl text-ink font-bold mb-6">
        Tim Kami
      </h2>

      {authors.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {authors.map((author) => {
            const displayName = author.fullname || author.username || 'Unknown';
            const initial = displayName.charAt(0).toUpperCase();
            return (
              <div class="border border-dust p-6 flex items-start gap-4 rounded-lg">
                <a href={`/authors/${author.username}`} class="shrink-0 no-underline">
                  {author.image ? (
                    <img
                      src={author.image}
                      alt={displayName}
                      class="w-16 h-16 object-cover rounded-full"
                    />
                  ) : (
                    <div class="w-16 h-16 rounded-full bg-parchment flex items-center justify-center border border-dust">
                      <span class="font-display text-xl text-ink">{initial}</span>
                    </div>
                  )}
                </a>
                <div class="min-w-0 flex-1">
                  <a
                    href={`/authors/${author.username}`}
                    class="font-display text-xl text-ink font-bold hover:text-ink-muted transition-colors no-underline"
                  >
                    {displayName}
                  </a>
                  {author.bio && (
                    <p class="text-sm text-ink-muted mt-1 leading-relaxed line-clamp-2">{author.bio}</p>
                  )}
                  <SocialLinks social={author.socialMedia} class="mt-2" />
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <p class="text-ink-muted text-sm italic">Belum ada penulis.</p>
      )}
    </section>
  </article>
</ListLayout>
