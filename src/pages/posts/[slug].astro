---
import PostLayout from '@/layouts/PostLayout.astro';
import PostInteractions from '@/components/blog/PostInteractions';
import Comments from '@/components/blog/Comments';
import SocialLinks from '@/components/shared/SocialLinks.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';
import '@/models/User';
import marked from '@/lib/markdown';

await connectDB();
const { slug } = Astro.params;
const post = await Post.findOne({ slug, status: 'published' })
  .populate('userId', 'fullname username image bio socialMedia')
  .lean();

if (!post) {
  return Astro.redirect('/404');
}

const postId = post._id.toString();
const content = marked.parse(post.content);
const formattedDate = new Date(post.createdAt).toLocaleDateString('id-ID', {
  day: 'numeric', month: 'long', year: 'numeric',
});
const author = post.userId;
const currentURL = Astro.url.href;
const shareText = encodeURIComponent(post.title);
const shareURL = encodeURIComponent(currentURL);
---

<PostLayout
  title={`${post.title} | Lostpeople`}
  description={post.excerpt}
  image={post.thumbnail || undefined}
>
  <article>
    <!-- Category tag -->
    {post.category && <span class="lp-tag">{post.category}</span>}

    <!-- Title -->
    <h1 class="lp-post-title">{post.title}</h1>

    <!-- Meta: date -->
    <div class="lp-post-meta">
      <time datetime={post.createdAt.toString()}>{formattedDate}</time>
    </div>

    <!-- Cover image -->
    {post.thumbnail && (
      <figure class="lp-cover">
        <img
          alt={post.title}
          src={post.thumbnail}
          loading="lazy"
        />
      </figure>
    )}
    {post.excerpt && (
      <div class="lp-caption">{post.excerpt}</div>
    )}

    <!-- Article body -->
    <div class="prose" set:html={content} />

    <!-- Tags + Share footer -->
    <footer class="lp-post-footer">
      {post.tags && post.tags.length > 0 && (
        <div class="lp-tag-chips">
          {post.tags.map((tag: string) => (
            <a href={`/tags/${tag}`} class="lp-tag-chip">{tag}</a>
          ))}
        </div>
      )}

      <hr class="lp-footer-divider" />

      <div class="lp-share">
        <span class="lp-share__label">Bagikan</span>
        <a
          href={`https://twitter.com/intent/tweet?text=${shareText}&url=${shareURL}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on Twitter / X"
          class="lp-share__btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z" />
          </svg>
          <span class="lp-share__label-text">X</span>
        </a>
        <a
          href={`https://www.facebook.com/sharer/sharer.php?u=${shareURL}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on Facebook"
          class="lp-share__btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
          </svg>
          <span class="lp-share__label-text">Facebook</span>
        </a>
        <a
          href={`https://api.whatsapp.com/send?text=${shareText}%20${shareURL}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on WhatsApp"
          class="lp-share__btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          <span class="lp-share__label-text">WhatsApp</span>
        </a>
        <button
          id="copy-link-btn"
          aria-label="Copy link"
          class="lp-share__btn"
        >
          <span class="material-symbols-outlined" style="font-size:1rem">link</span>
          <span class="lp-share__label-text">Salin tautan</span>
        </button>
      </div>
    </footer>

    <!-- Author -->
    {author && (
      <div class="border border-dust p-5 flex items-start gap-4 rounded-lg mt-6">
        <a href={`/authors/${author.username}`} class="shrink-0 no-underline">
          {author.image ? (
            <img
              alt={author.fullname}
              src={author.image}
              class="w-14 h-14 object-cover rounded-full border border-dust"
            />
          ) : (
            <div class="w-14 h-14 rounded-full bg-parchment flex items-center justify-center border border-dust">
              <span class="font-display text-xl text-ink">
                {(author.fullname || author.username || '?').charAt(0).toUpperCase()}
              </span>
            </div>
          )}
        </a>
        <div class="min-w-0 flex-1">
          <a
            href={`/authors/${author.username}`}
            class="font-display text-lg text-ink font-bold hover:text-ink-muted transition-colors no-underline"
          >
            {author.fullname || author.username}
          </a>
          {author.bio && (
            <p class="text-sm text-ink-muted mt-0.5 leading-relaxed">{author.bio}</p>
          )}
          <div class="flex items-center gap-3 mt-2">
            <SocialLinks social={author.socialMedia} />
            <a
              href={`/authors/${author.username}`}
              class="font-ui text-xs text-ink-ghost hover:text-accent transition-colors no-underline"
            >
              Semua tulisan →
            </a>
          </div>
        </div>
      </div>
    )}

    <!-- Likes + Comments -->
    <div class="lp-comments">
      <PostInteractions client:load postId={postId} initialLikes={post.likesCount || 0} />
      <Comments client:load postId={postId} />
    </div>
  </article>
</PostLayout>

<script>
  function initCopyLink() {
    const copyBtn = document.getElementById('copy-link-btn');
    copyBtn?.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        const orig = copyBtn.innerHTML;
        copyBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:1rem">check</span> Tersalin!';
        setTimeout(() => {
          copyBtn.innerHTML = orig;
        }, 2000);
      });
    });
  }
  document.addEventListener('astro:page-load', initCopyLink);
</script>
