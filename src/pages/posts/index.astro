---
export const prerender = true;

import ListLayout from '@/layouts/ListLayout.astro';
import PostItem from '@/components/blog/PostItem.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';
import '@/models/User';

let posts: any[] = [];
try {
  await connectDB();
  posts = await Post.find({ status: 'published' })
    .sort({ createdAt: -1 })
    .populate('userId', 'fullname username image')
    .lean();
} catch (e) {
  console.warn('Could not connect to database during build:', e);
}
---

<ListLayout
  title="Posts | Lostpeople"
  description="Artikel inspiratif tentang kehidupan dan teknologi"
>
  {posts.length > 0 ? (
    <>
      <span class="lp-section-label">Semua tulisan</span>
      <div class="lp-post-list">
        {posts.map((post) => <PostItem post={post} />)}
      </div>
    </>
  ) : (
    <p style="font-family:var(--font-body); font-style:italic; color:var(--color-ink-ghost); font-size:var(--text-sm);">
      Belum ada artikel.
    </p>
  )}
</ListLayout>
