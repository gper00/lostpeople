---
export const prerender = false;

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { requireAdminPage } from '@/lib/require-admin';

const denied = requireAdminPage(Astro);
if (denied) return denied;
---

<DashboardLayout title="New User | Lostpeople Dashboard">
  <div class="max-w-xl">
    <div class="mb-stack-lg">
      <a
        href="/dashboard/users"
        class="inline-flex items-center gap-1 font-label-sm text-label-sm text-secondary hover:text-primary transition-colors no-underline mb-4"
      >
        <span class="material-symbols-outlined text-[16px]">arrow_back</span>
        Users
      </a>
      <h1 class="font-headline-lg text-headline-lg text-primary">New User</h1>
      <p class="font-meta-italic text-meta-italic text-secondary mt-1">
        Admin creates accounts directly — there is no public sign-up.
      </p>
    </div>

    <form id="user-form" class="flex flex-col gap-stack-md">
      <div>
        <label for="fullname" class="font-label-sm text-label-sm text-secondary block mb-1">Full name</label>
        <input type="text" id="fullname" required minlength="5"
          class="w-full px-3 py-2 border border-border-subtle bg-transparent text-primary font-body-md focus:outline-none focus:border-primary transition-colors" />
      </div>
      <div>
        <label for="username" class="font-label-sm text-label-sm text-secondary block mb-1">Username</label>
        <input type="text" id="username"
          class="w-full px-3 py-2 border border-border-subtle bg-transparent text-primary font-body-md focus:outline-none focus:border-primary transition-colors" />
      </div>
      <div>
        <label for="email" class="font-label-sm text-label-sm text-secondary block mb-1">Email</label>
        <input type="email" id="email" required
          class="w-full px-3 py-2 border border-border-subtle bg-transparent text-primary font-body-md focus:outline-none focus:border-primary transition-colors" />
      </div>
      <div>
        <label for="password" class="font-label-sm text-label-sm text-secondary block mb-1">Password</label>
        <input type="password" id="password" required minlength="8"
          class="w-full px-3 py-2 border border-border-subtle bg-transparent text-primary font-body-md focus:outline-none focus:border-primary transition-colors" />
      </div>
      <div>
        <label for="role" class="font-label-sm text-label-sm text-secondary block mb-1">Role</label>
        <select id="role"
          class="w-full px-3 py-2 border border-border-subtle bg-transparent text-primary font-body-md focus:outline-none focus:border-primary transition-colors">
          <option value="user">user</option>
          <option value="admin">admin</option>
        </select>
      </div>

      <div id="error-message" class="text-red-600 font-label-sm text-label-sm hidden"></div>

      <div class="flex items-center gap-3">
        <button type="submit" id="submit-btn"
          class="px-6 py-3 bg-primary text-background font-label-sm text-label-sm tracking-wider uppercase hover:bg-on-surface-variant transition-colors cursor-pointer border-0">
          Create User
        </button>
        <a href="/dashboard/users" class="font-label-sm text-label-sm text-secondary hover:text-primary transition-colors no-underline">Cancel</a>
      </div>
    </form>
  </div>
</DashboardLayout>

<script>
  import { authClient } from '@/lib/auth-client';
  import { toast } from '@/lib/ui';

  const form = document.getElementById('user-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-message')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    submitBtn.textContent = 'Creating...';
    submitBtn.disabled = true;

    const fullname = (document.getElementById('fullname') as HTMLInputElement).value.trim();
    const username = (document.getElementById('username') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const role = (document.getElementById('role') as HTMLSelectElement).value as 'user' | 'admin';

    const { data, error } = await authClient.admin.createUser({
      name: fullname,
      email,
      password,
      role,
      data: { fullname, username: username || undefined },
    });

    if (error) {
      errorMsg.textContent = error.message || 'Failed to create user';
      errorMsg.classList.remove('hidden');
      toast(error.message || 'Failed to create user', 'error');
      submitBtn.textContent = 'Create User';
      submitBtn.disabled = false;
      return;
    }

    toast('User created', 'success');
    const newId = (data as any)?.user?.id;
    setTimeout(() => {
      window.location.href = newId ? `/dashboard/users/${newId}` : '/dashboard/users';
    }, 500);
  });
</script>
