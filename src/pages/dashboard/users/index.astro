---
export const prerender = false;

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { connectDB } from '@/lib/db';
import User from '@/models/User';
import { requireAdminPage } from '@/lib/require-admin';

const denied = requireAdminPage(Astro);
if (denied) return denied;

const currentUserId = Astro.locals.user!.id;

let users: any[] = [];
try {
  await connectDB();
  users = await User.find({}).sort({ createdAt: -1 }).lean();
} catch (e) {
  console.warn('Could not connect to database:', e);
}
---

<DashboardLayout title="Users | Lostpeople Dashboard">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="font-display text-2xl text-ink mb-2">Users</h1>
      <p class="text-sm text-ink-muted italic">
        {users.length} user{users.length !== 1 ? 's' : ''}
      </p>
    </div>
    <a
      href="/dashboard/users/create"
      class="lp-btn-primary"
    >
      <span class="material-symbols-outlined text-[16px]">person_add</span>
      New User
    </a>
  </div>

  {users.length > 0 ? (
    <div class="border border-dust rounded-lg divide-y divide-dust overflow-hidden">
      {users.map((u) => (
        <div class="relative flex items-center justify-between gap-3 px-5 py-3 hover:bg-parchment transition-colors">
          <div class="flex items-center gap-3 min-w-0">
            {u.image ? (
              <img src={u.image} alt={u.fullname} class="w-9 h-9 object-cover rounded-full shrink-0" />
            ) : (
              <div class="w-9 h-9 rounded-full bg-parchment flex items-center justify-center shrink-0 border border-dust font-ui text-xs text-ink-muted">
                {(u.fullname || u.email || '?').charAt(0).toUpperCase()}
              </div>
            )}
            <div class="min-w-0">
              <a
                href={`/dashboard/users/${u._id}`}
                class="font-ui text-sm text-ink hover:text-ink-muted transition-colors no-underline block truncate before:absolute before:inset-0 before:content-['']"
              >
                {u.fullname || u.name || '(no name)'}
                {String(u._id) === currentUserId && (
                  <span class="font-ui text-xs text-ink-muted italic"> · you</span>
                )}
              </a>
              <span class="font-ui text-xs text-ink-muted block truncate">
                {u.email}
              </span>
            </div>
          </div>
          <div class="relative z-10 flex items-center gap-2 shrink-0">
            <span class:list={[
              'px-2 py-0.5 text-[11px] uppercase tracking-wider rounded',
              u.role === 'admin' ? 'bg-accent-soft text-accent-dark' : 'bg-gray-100 text-gray-800',
            ]}>
              {u.role || 'user'}
            </span>
            {u.banned && (
              <span class="px-2 py-0.5 text-[11px] uppercase tracking-wider rounded bg-red-100 text-red-800">
                banned
              </span>
            )}
            <a
              href={`/dashboard/users/${u._id}`}
              title="Edit user"
              aria-label="Edit user"
              class="p-2 text-ink-muted hover:text-ink hover:bg-parchment transition-colors no-underline flex items-center rounded"
            >
              <span class="material-symbols-outlined text-[18px]">edit</span>
            </a>
            {String(u._id) !== currentUserId && (
              <button
                class="delete-user-btn p-2 text-ink-muted hover:text-red-600 hover:bg-red-50 transition-colors cursor-pointer bg-transparent border-0 flex items-center rounded"
                data-id={String(u._id)}
                data-name={u.fullname || u.email}
                title="Delete user"
                aria-label="Delete user"
              >
                <span class="material-symbols-outlined text-[18px]">delete</span>
              </button>
            )}
          </div>
        </div>
      ))}
    </div>
  ) : (
    <div class="border border-dust rounded-lg p-6 text-center">
      <p class="text-sm text-ink-muted italic">No users found.</p>
    </div>
  )}
</DashboardLayout>

<script>
  import { authClient } from '@/lib/auth-client';
  import { toast, confirmDialog } from '@/lib/ui';

  document.querySelectorAll('.delete-user-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const id = el.dataset.id!;
      const name = el.dataset.name || 'this user';

      const ok = await confirmDialog({
        title: 'Delete user',
        message: `Delete ${name}? This cannot be undone.`,
        confirmLabel: 'Delete',
        danger: true,
      });
      if (!ok) return;

      el.disabled = true;
      const { error } = await authClient.admin.removeUser({ userId: id });
      if (error) {
        toast(error.message || 'Failed to delete user', 'error');
        el.disabled = false;
        return;
      }
      toast('User deleted', 'success');
      setTimeout(() => window.location.reload(), 600);
    });
  });
</script>
