---
export const prerender = false;

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import MarkdownEditor from '@/components/dashboard/MarkdownEditor';
import ImageUpload from '@/components/dashboard/ImageUpload.astro';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}
---

<DashboardLayout title="Create Post | Lostpeople Dashboard">
  <div class="mb-8">
    <a href="/dashboard/posts" class="lp-back">
      <span class="material-symbols-outlined" style="font-size:0.875rem">arrow_back</span>
      Posts
    </a>
    <h1 class="font-display text-2xl text-ink">Create Post</h1>
  </div>

  <form id="create-post-form" class="flex flex-col gap-5 max-w-5xl">
    <!-- Title -->
    <div>
      <label for="title" class="font-ui text-xs text-ink-muted block mb-1">Title</label>
      <input
        type="text"
        id="title"
        name="title"
        required
        minlength={10}
        maxlength={255}
        class="w-full px-3 py-2 border border-dust bg-parchment text-ink-body text-base rounded-lg focus:outline-none focus:border-accent transition-colors"
        placeholder="Post title"
      />
    </div>

    <!-- Excerpt -->
    <div>
      <label for="excerpt" class="font-ui text-xs text-ink-muted block mb-1">Excerpt</label>
      <textarea
        id="excerpt"
        name="excerpt"
        required
        minlength={30}
        maxlength={500}
        rows={3}
        class="w-full px-3 py-2 border border-dust bg-parchment text-ink-body text-base rounded-lg focus:outline-none focus:border-accent transition-colors resize-y"
        placeholder="Brief description of the post"
      ></textarea>
    </div>

    <!-- Content -->
    <div>
      <label class="font-ui text-xs text-ink-muted block mb-1">Content</label>
      <MarkdownEditor client:load content="" targetId="content" />
      <input type="hidden" id="content" name="content" />
    </div>

    <!-- Category -->
    <div>
      <label for="category" class="font-ui text-xs text-ink-muted block mb-1">Category</label>
      <input
        type="text"
        id="category"
        name="category"
        maxlength={25}
        class="w-full px-3 py-2 border border-dust bg-parchment text-ink-body text-base rounded-lg focus:outline-none focus:border-accent transition-colors"
        placeholder="e.g., Technology, Life, Philosophy"
      />
    </div>

    <!-- Tags -->
    <div>
      <label for="tags" class="font-ui text-xs text-ink-muted block mb-1">Tags (comma separated)</label>
      <input
        type="text"
        id="tags"
        name="tags"
        class="w-full px-3 py-2 border border-dust bg-parchment text-ink-body text-base rounded-lg focus:outline-none focus:border-accent transition-colors"
        placeholder="e.g., javascript, react, web"
      />
    </div>

    <!-- Thumbnail -->
    <div>
      <ImageUpload name="thumbnail" label="Thumbnail" />
    </div>

    <!-- Status -->
    <div>
      <label for="status" class="font-ui text-xs text-ink-muted block mb-1">Status</label>
      <select
        id="status"
        name="status"
        class="w-full px-3 py-2 border border-dust bg-parchment text-ink-body text-base rounded-lg focus:outline-none focus:border-accent transition-colors"
      >
        <option value="draft">Draft</option>
        <option value="published">Published</option>
      </select>
    </div>

    <!-- Error message -->
    <div id="error-message" class="text-red-600 font-ui text-xs hidden"></div>

    <!-- Submit -->
    <div class="flex items-center gap-3 mt-5">
      <button type="submit" id="submit-btn" class="lp-btn-primary">
        Create Post
      </button>
      <a href="/dashboard/posts" class="lp-btn-ghost">
        Cancel
      </a>
    </div>
  </form>
</DashboardLayout>

<script>
  import { toast } from '@/lib/ui';

  const form = document.getElementById('create-post-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-message')!;
  const submitBtn = document.getElementById('submit-btn')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    submitBtn.textContent = 'Creating...';
    (submitBtn as HTMLButtonElement).disabled = true;

    const formData = new FormData(form);
    const title = formData.get('title') as string;
    const content = (document.getElementById('content') as HTMLInputElement).value;
    const excerpt = formData.get('excerpt') as string;
    const category = formData.get('category') as string;
    const tagsStr = formData.get('tags') as string;
    const thumbnail = formData.get('thumbnail') as string;
    const status = formData.get('status') as string;

    const tags = tagsStr ? tagsStr.split(',').map(t => t.trim()).filter(Boolean) : [];

    try {
      const res = await fetch('/api/posts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, content, excerpt, category, tags, thumbnail, status }),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Failed to create post');
      }

      toast('Post created', 'success');
      window.location.href = '/dashboard/posts';
    } catch (err: any) {
      errorMsg.textContent = err.message || 'An error occurred';
      errorMsg.classList.remove('hidden');
      submitBtn.textContent = 'Create Post';
      (submitBtn as HTMLButtonElement).disabled = false;
    }
  });
</script>
