---
export const prerender = false;

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

let posts: any[] = [];
try {
  await connectDB();
  posts = await Post.find({ userId: user.id })
    .sort({ createdAt: -1 })
    .lean();
} catch (e) {
  console.warn('Could not connect to database:', e);
}
---

<DashboardLayout title="Posts | Lostpeople Dashboard">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="font-display text-2xl text-ink mb-2">Posts</h1>
      <p class="text-sm text-ink-muted italic">
        {posts.length} post{posts.length !== 1 ? 's' : ''}
      </p>
    </div>
    <a
      href="/dashboard/posts/create"
      class="lp-btn-primary"
    >
      <span class="material-symbols-outlined text-[16px]">add</span>
      New Post
    </a>
  </div>

  {posts.length > 0 ? (
    <div class="border border-dust rounded-lg divide-y divide-dust overflow-hidden">
      {posts.map((post) => (
        <div class="relative flex items-center justify-between gap-3 px-5 py-3 hover:bg-parchment transition-colors">
          <div class="flex-1 min-w-0">
            <a
              href={`/dashboard/posts/${post._id}`}
              class="font-ui text-sm text-ink hover:text-ink-muted transition-colors no-underline block truncate before:absolute before:inset-0 before:content-['']"
            >
              {post.title}
            </a>
            <div class="flex items-center gap-3 mt-1">
              <span class="font-ui text-xs text-ink-muted">
                {new Date(post.createdAt).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </span>
              <span class:list={[
                'px-2 py-0.5 text-[11px] uppercase tracking-wider rounded',
                post.status === 'published'
                  ? 'bg-green-100 text-green-800'
                  : post.status === 'draft'
                  ? 'bg-yellow-100 text-yellow-800'
                  : 'bg-gray-100 text-gray-800',
              ]}>
                {post.status}
              </span>
              {post.category && (
                <span class="font-ui text-xs text-ink-muted hidden sm:inline">
                  {post.category}
                </span>
              )}
              <span class="inline-flex items-center gap-1 font-ui text-xs text-ink-muted" title="Views">
                <span class="material-symbols-outlined text-[14px]">visibility</span>
                {post.viewsCount || 0}
              </span>
              <span class="inline-flex items-center gap-1 font-ui text-xs text-ink-muted" title="Likes">
                <span class="material-symbols-outlined text-[14px]">favorite</span>
                {post.likesCount || 0}
              </span>
            </div>
          </div>
          <div class="relative z-10 flex items-center gap-0.5 shrink-0">
            {post.status === 'published' && post.slug && (
              <a
                href={`/posts/${post.slug}`}
                target="_blank"
                rel="noopener"
                title="View live post"
                aria-label="View live post"
                class="p-2 text-ink-muted hover:text-ink hover:bg-parchment transition-colors no-underline flex items-center rounded"
              >
                <span class="material-symbols-outlined text-[18px]">open_in_new</span>
              </a>
            )}
            <a
              href={`/dashboard/posts/${post._id}`}
              title="Edit post"
              aria-label="Edit post"
              class="p-2 text-ink-muted hover:text-ink hover:bg-parchment transition-colors no-underline flex items-center rounded"
            >
              <span class="material-symbols-outlined text-[18px]">edit</span>
            </a>
            <button
              class="delete-btn p-2 text-ink-muted hover:text-red-600 hover:bg-red-50 transition-colors cursor-pointer bg-transparent border-0 flex items-center rounded"
              data-id={post._id}
              data-title={post.title}
              title="Delete post"
              aria-label="Delete post"
            >
              <span class="material-symbols-outlined text-[18px]">delete</span>
            </button>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <div class="border border-dust rounded-lg p-6 text-center">
      <p class="text-sm text-ink-muted italic mb-3">
        No posts yet
      </p>
      <a
        href="/dashboard/posts/create"
        class="font-ui text-xs text-ink-muted hover:text-ink transition-colors no-underline"
      >
        Create your first post →
      </a>
    </div>
  )}
</DashboardLayout>

<script>
  import { toast, confirmDialog } from '@/lib/ui';

  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const id = el.dataset.id;
      const title = el.dataset.title || 'this post';

      const ok = await confirmDialog({
        title: 'Delete post',
        message: `Delete “${title}”? This cannot be undone.`,
        confirmLabel: 'Delete',
        danger: true,
      });
      if (!ok) return;

      try {
        const res = await fetch(`/api/posts/${id}`, { method: 'DELETE' });
        if (!res.ok) throw new Error('Request failed');
        toast('Post deleted', 'success');
        setTimeout(() => window.location.reload(), 600);
      } catch (err) {
        toast('Failed to delete post', 'error');
        console.error('Delete failed:', err);
      }
    });
  });
</script>
