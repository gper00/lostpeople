---
export const prerender = true;

import ListLayout from '@/layouts/ListLayout.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';

let allTags: { name: string; count: number }[] = [];

try {
  await connectDB();
  const posts = await Post.find({ status: 'published' }).lean();
  const tagMap = new Map<string, number>();
  for (const post of posts) {
    for (const tag of post.tags || []) {
      tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
    }
  }
  allTags = Array.from(tagMap.entries())
    .map(([name, count]) => ({ name, count }))
    .sort((a, b) => b.count - a.count);
} catch (e) {
  console.warn('Could not connect to database during build:', e);
}
---

<ListLayout title="Tags | Lostpeople" description="Semua topik di Lostpeople">
  <span class="lp-section-label">Semua topik</span>
  {allTags.length > 0 ? (
    <div class="lp-tag-grid">
      {allTags.map(({ name, count }) => (
        <a href={`/tags/${encodeURIComponent(name)}`} class="lp-tag-card">
          <span class="lp-tag-card__name">{name}</span>
          <span class="lp-tag-card__count">{count} tulisan</span>
        </a>
      ))}
    </div>
  ) : (
    <p style="font-family:var(--font-body); font-style:italic; color:var(--color-ink-ghost); font-size:var(--text-sm);">
      Belum ada topik.
    </p>
  )}
</ListLayout>
