---
import ListLayout from '@/layouts/ListLayout.astro';
import PostItem from '@/components/blog/PostItem.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';
import '@/models/User';

await connectDB();
const { tag: decodedTag } = Astro.params;

const posts = await Post.find({ status: 'published', tags: decodedTag })
  .sort({ createdAt: -1 })
  .populate('userId', 'fullname username image')
  .lean();
---

<ListLayout
  title={`#${decodedTag} | Lostpeople`}
  description={`Posts tagged with ${decodedTag}`}
  keywords={decodedTag}
>
  <div class="mb-10">
    <a href="/tags" class="lp-back">
      <span class="material-symbols-outlined" style="font-size:0.875rem">arrow_back</span>
      Tags
    </a>
    <h1 class="font-display text-3xl text-ink mb-1 font-bold">
      #{decodedTag}
    </h1>
    <p class="text-sm text-ink-muted italic">
      {posts.length} post{posts.length !== 1 ? 's' : ''}
    </p>
  </div>

  {posts.length > 0 ? (
    <div class="lp-post-list">
      {posts.map((post) => <PostItem post={post} />)}
    </div>
  ) : (
    <p class="text-sm text-ink-muted italic">No posts with this tag.</p>
  )}
</ListLayout>
