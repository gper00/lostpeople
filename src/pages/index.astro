---
import BlogLayout from '@/layouts/BlogLayout.astro';
import PostItem from '@/components/blog/PostItem.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';
import '@/models/User';

let posts: any[] = [];
try {
  await connectDB();
  posts = await Post.find({ status: 'published' })
    .sort({ createdAt: -1 })
    .limit(10)
    .populate('userId', 'fullname username image')
    .lean();
} catch (e) {
  console.warn('Could not connect to database:', e);
}
---

<BlogLayout
  title="Lostpeople"
  description="Blog inspiratif tentang kehidupan dan teknologi"
>
  {posts.length > 0 ? (
    <>
      <div class="decorative-line"></div>
      <div class="flex flex-col gap-stack-lg">
        {posts.map((post) => <PostItem post={post} />)}
      </div>
    </>
  ) : (
    <p class="font-body-md text-secondary italic">Belum ada artikel.</p>
  )}
</BlogLayout>
