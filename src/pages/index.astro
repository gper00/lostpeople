---
import ListLayout from '@/layouts/ListLayout.astro';
import PostItem from '@/components/blog/PostItem.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';
import '@/models/User';

let posts: any[] = [];
try {
  await connectDB();
  posts = await Post.find({ status: 'published' })
    .sort({ createdAt: -1 })
    .limit(10)
    .populate('userId', 'fullname username image')
    .lean();
} catch (e) {
  console.warn('Could not connect to database:', e);
}
---

<ListLayout
  title="Lostpeople"
  description="Blog inspiratif tentang kehidupan dan teknologi"
>
  {posts.length > 0 ? (
    <>
      <span class="lp-section-label">Tulisan terbaru</span>
      <div class="lp-post-list">
        {posts.map((post) => <PostItem post={post} />)}
      </div>
    </>
  ) : (
    <div style="padding:3rem 0; text-align:center; color:var(--color-ink-ghost);">
      <p style="font-family:var(--font-display); font-style:italic; font-size:var(--text-xl); margin-bottom:0.5rem;">Belum ada tulisan.</p>
      <p style="font-family:var(--font-ui); font-size:var(--text-sm);">Nantikan tulisan pertama.</p>
    </div>
  )}
</ListLayout>
