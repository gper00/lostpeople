---
import ListLayout from '@/layouts/ListLayout.astro';
import PostItem from '@/components/blog/PostItem.astro';
import SocialLinks from '@/components/shared/SocialLinks.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';
import User from '@/models/User';

await connectDB();
const { username } = Astro.params;

const author = await User.findOne({ username }).lean();

if (!author) {
  return Astro.redirect('/404');
}

const posts = await Post.find({ userId: author._id, status: 'published' })
  .sort({ createdAt: -1 })
  .populate('userId', 'fullname username image')
  .lean();

const displayName = author.fullname || author.username;
---

<ListLayout
  title={`${displayName} | Lostpeople`}
  description={author.bio || `Tulisan oleh ${displayName}`}
  image={author.image || undefined}
>
  <article>
    <!-- Author header -->
    <header class="mb-8">
      <a href="/about" class="lp-back">
        <span class="material-symbols-outlined" style="font-size:0.875rem">arrow_back</span>
        Authors
      </a>

      <div class="flex items-start gap-5">
        {author.image ? (
          <img
            src={author.image}
            alt={displayName}
            class="w-20 h-20 object-cover rounded-full shrink-0"
          />
        ) : (
          <div class="w-20 h-20 rounded-full bg-parchment flex items-center justify-center shrink-0 border border-dust">
            <span class="font-display text-2xl text-ink">{displayName.charAt(0).toUpperCase()}</span>
          </div>
        )}

        <div class="min-w-0">
          <h1 class="font-display text-3xl text-ink leading-tight font-bold">
            {displayName}
          </h1>
          {author.username && (
            <p class="text-xs text-ink-muted italic">@{author.username}</p>
          )}
          {author.bio && (
            <p class="text-ink-muted text-base leading-relaxed mt-2">{author.bio}</p>
          )}
          <SocialLinks social={author.socialMedia} class="mt-3" />
        </div>
      </div>
    </header>

    <div class="w-full h-px bg-dust mb-6"></div>

    <!-- Posts by this author -->
    <h2 class="font-display text-xl text-ink mb-6">
      {posts.length} {posts.length === 1 ? 'post' : 'posts'}
    </h2>

    {posts.length > 0 ? (
      <div class="lp-post-list">
        {posts.map((post) => <PostItem post={post} />)}
      </div>
    ) : (
      <p class="text-sm text-ink-muted italic">Belum ada tulisan.</p>
    )}
  </article>
</ListLayout>
