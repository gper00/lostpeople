---
import BlogLayout from '@/layouts/BlogLayout.astro';
import PostItem from '@/components/blog/PostItem.astro';
import SocialLinks from '@/components/shared/SocialLinks.astro';
import { connectDB } from '@/lib/db';
import Post from '@/models/Post';
import User from '@/models/User';

await connectDB();
const { username } = Astro.params;

const author = await User.findOne({ username }).lean();

if (!author) {
  return Astro.redirect('/404');
}

const posts = await Post.find({ userId: author._id, status: 'published' })
  .sort({ createdAt: -1 })
  .populate('userId', 'fullname username image')
  .lean();

const displayName = author.fullname || author.username;
---

<BlogLayout
  title={`${displayName} | Lostpeople`}
  description={author.bio || `Tulisan oleh ${displayName}`}
  image={author.image || undefined}
>
  <article>
    <!-- Author header -->
    <header class="mb-stack-lg">
      <a
        href="/about"
        class="inline-flex items-center gap-1 font-label-sm text-label-sm text-secondary hover:text-primary transition-colors no-underline mb-stack-md"
      >
        <span class="material-symbols-outlined text-[16px]">arrow_back</span>
        Authors
      </a>

      <div class="flex items-start gap-5">
        {author.image ? (
          <img
            src={author.image}
            alt={displayName}
            class="w-20 h-20 object-cover rounded-full shrink-0"
          />
        ) : (
          <div class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
            <span class="font-display-lg text-2xl text-primary">{displayName.charAt(0).toUpperCase()}</span>
          </div>
        )}

        <div class="min-w-0">
          <h1 class="font-display-lg text-[2rem] text-primary leading-tight font-bold">
            {displayName}
          </h1>
          {author.username && (
            <p class="font-meta-italic text-meta-italic text-secondary">@{author.username}</p>
          )}
          {author.bio && (
            <p class="text-secondary text-body-md leading-relaxed mt-2">{author.bio}</p>
          )}
          <SocialLinks social={author.socialMedia} class="mt-3" />
        </div>
      </div>
    </header>

    <div class="decorative-line"></div>

    <!-- Posts by this author -->
    <h2 class="font-headline-md text-headline-md text-primary mb-stack-md">
      {posts.length} {posts.length === 1 ? 'post' : 'posts'}
    </h2>

    {posts.length > 0 ? (
      <div class="flex flex-col gap-stack-lg">
        {posts.map((post) => <PostItem post={post} />)}
      </div>
    ) : (
      <p class="font-body-md text-secondary italic">Belum ada tulisan.</p>
    )}
  </article>
</BlogLayout>
