<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>Admin Login | Lostpeople</title>

        <link rel="stylesheet" href="/css/dashtemplate.css" />
        <link
            rel="stylesheet"
            href="/assets/bootstrap-icons-1.11.3/font/bootstrap-icons.min.css"
        />
        <style>

          .my-form {
              width: 345px;
              position: absolute;
              top: 48%;
              left: 50%;
              transform: translate(-50%, -50%);
          }

          .login-alert {
              width: 345px;
              position: absolute;
              top: 15%;
              left: 50%;
              transform: translate(-50%, -50%);
          }
          @media (max-width: 500px) {
          .my-form {
              min-width: 90%;
          }
          .login-alert {
              min-width: 90%;
          }
}
        </style>
    </head>
    <body class="bg-light text-body-secondary">
        <% if (errorMessage.length) { %>
        <div
            class="alert rounded login-alert d-flex justify-content-between align-items-center bg-danger p-3"
        >
            <span>
                <%= errorMessage %>
            </span>
            <button
                type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Close"
            ></button>
        </div>
        <% } %>

        <div class="my-form card p-4">
            <form method="POST">
                <h1 class="text-center fw-bolder fs-3 mt-3 pb-4 mb-3">
                    Admin Login
                </h1>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="form-group mb-4">
                    <label for="usernameOrEmail" class="form-label mb-1"
                        >Username or Email</label
                    >
                    <input
                        type="text"
                        class="form-control <%= errors && errors.usernameOrEmail ? 'is-invalid' : '' %>"
                        id="usernameOrEmail"
                        name="usernameOrEmail"
                        autocomplete="off"
                        value="<%= userData.usernameOrEmail ?? '' %>"
                        required
                        autofocus
                    />
                    <% if (errors && errors.usernameOrEmail) { %>
                    <div class="invalid-feedback">
                        <%= errors.usernameOrEmail.msg %>
                    </div>
                    <% } %>
                </div>
                <div class="form-group mb-4">
                    <label for="password" class="form-label mb-1"
                        >Password</label
                    >
                    <input
                        type="password"
                        class="form-control <%= errors && errors.password ? 'is-invalid' : '' %>"
                        id="password"
                        name="password"
                        value=""
                        required
                    />
                    <% if (errors && errors.password) { %>
                    <div class="invalid-feedback">
                        <%= errors.password.msg %>
                    </div>
                    <% } %>
                </div>
                <div class="form-check mb-4">
                    <input type="checkbox" class="form-check-input shadow-none"
                    id="rememberMe" name="rememberMe" <%= userData.rememberMe ?
                    'checked' : '' %> />
                    <label class="form-check-label" for="rememberMe"
                        >Remember me</label
                    >
                </div>
                <button type="submit" class="btn btn-primary w-100 mb-2">
                    Log in
                </button>
            </form>
        </div>

        <script src="/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
