<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, shrink-to-fit=no"
        />

        <title>Admin Dashboard | Lostpeople</title>

        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
            crossorigin="anonymous"
        >
        <link href="/css/dashtemplate.css" rel="stylesheet" />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=M+PLUS+Rounded+1c:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
        <link href="/css/dashboard.css" rel="stylesheet" />
    </head>

    <body>
        <!-- Logout -->
        <form
            id="logout-form"
            action="/dashboard/logout?_csrf=<%= csrfToken %>"
            method="POST"
            style="display: none"
        ></form>

        <div class="wrapper">
            <%- include('../partials/dashboard-sidebar') %>

            <div class="main">
                <%- include('../partials/dashboard-navbar') %>

                <!-- Page content -->
                <%- body %>

                <!-- <%- include('../partials/dashboard-footer') %> -->
            </div>
        </div>

        <!-- User modal -->
        <div
            class="modal fade"
            id="userDetail"
            tabindex="-1"
            aria-labelledby="userDetailLabel"
            aria-hidden="true"
        >
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title" id="userDetailLabel">
                            My Profile
                        </h4>
                        <button
                            type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"
                            aria-label="Close"
                        ></button>
                    </div>
                    <div class="modal-body d-flex py-0">
                        <div class="align-self-center w-100">
                            <table class="table mb-0">
                                <tbody>
                                    <% if (authUser.image) { %>
                                    <tr>
                                        <td colspan="2">
                                            <div class="py-3 text-center mb-2">
                                                <img
                                                    src="<%= authUser.image %>"
                                                    alt="<%= authUser.fullname %>"
                                                    class="img-profile img-thumbnail"
                                                    style="width: 200px; height: 200px;"
                                                />
                                            </div>
                                        </td>
                                    </tr>
                                    <% } %>
                                    <tr>
                                        <td class="w-25">Fullname</td>
                                        <td class="text-end w-75">
                                            <%= authUser.fullname %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Username</td>
                                        <td class="text-end">
                                            <%= authUser.username %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Email</td>
                                        <td class="text-end">
                                            <%= authUser.email %>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <a
                            class="btn text-primary"
                            href="/dashboard/users/<%= authUser._id %>"
                        >More</a>
                        <a
                            class="btn btn-primary"
                            href="/dashboard/users/<%= authUser._id %>/edit"
                        >Edit</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Logout modal -->
        <div
            class="modal fade"
            id="logoutAction"
            tabindex="-1"
            aria-labelledby="logoutActionLabel"
            aria-hidden="true"
        >
            <div class="modal-dialog modal-sm modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-body text-center pt-5 pb-4 px-5">
                        <div class="mb-4">
                            <div class="fs-4 fw-bolder mb-2">Are you sure?</div>
                            This action will end your active session!
                        </div>
                        <div class="mb-2">
                            <button
                                class="btn btn-primary"
                                onclick="document.getElementById('logout-form').submit();"
                            >
                                Logout
                            </button>
                            <button
                                type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal"
                            >
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- <script src="/js/bootstrap.bundle.min.js"></script> -->
        <script src="/js/bootstrap.bundle.min"></script>
        <script src="/js/dashtemplate.js"></script>
        <script src="/js/dashboard-custom.js"></script>
        <script>
          // image preview
          try {
              document.querySelector('#image').onchange = function () {
                  let file = this.files[0]
                  if (file) {
                      let reader = new FileReader()
                      reader.onload = function (event) {
                          document
                              .querySelector('#imgPreview')
                              .setAttribute('src', event.target.result)
                          document
                              .querySelector('.imgPreviewContainer')
                              .classList.remove('d-none')
                      }
                      reader.readAsDataURL(file)
                  }
              }
          } catch (error) {
              console.log(error)
          }

          // cancel button
          try {
              document.getElementById('cancel-button').onclick = () => {
                  const isConfirmed = confirm('Are you sure ?')

                  if (isConfirmed) {
                      return history.go(-1)
                  }
              }
          } catch (error) {
              console.log(error)
          }
        </script>
    </body>
</html>
