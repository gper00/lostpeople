<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "<%= typeof post !== 'undefined' && post ? 'BlogPosting' : 'WebSite' %>",
  <% if (typeof post !== 'undefined' && post) { %>
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "<%= site.url %>/<%= post.slug %>"
  },
  "headline": "<%= post.title %>",
  "description": "<%= post.excerpt %>",
  "image": "<%= post.thumbnail || (site.url + site.image) %>",
  "author": {
    "@type": "Person",
    "name": "<%= author.name %>",
    "url": "<%= author.socials.github %>"
  },
  "publisher": {
    "@type": "Organization",
    "name": "<%= site.title %>",
    "logo": {
      "@type": "ImageObject",
      "url": "<%= site.url + site.favicon %>"
    }
  },
  "datePublished": "<%= post.createdAt.toISOString() %>",
  "dateModified": "<%= post.updatedAt.toISOString() %>"
  <% } else { %>
  "url": "<%= site.url %>",
  "name": "<%= site.title %>",
  "description": "<%= site.description %>",
  "author": {
    "@type": "Person",
    "name": "<%= author.name %>",
    "url": "<%= author.socials.github %>"
  }
  <% } %>
}
</script>