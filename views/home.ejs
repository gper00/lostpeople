<%- include('partials/header-bs') %>

<!-- Page content-->
<div class="container-md col-lg-10 col-xl-9 col-xxl-8 my-5">
    <div class="row">
        <!-- Side widget 1 -->
        <div class="col-lg-2 d-none d-lg-block">
            <div class="position-sticky" style="top: 2rem">
                <h6 class=""><i class="bi bi-folder"></i> Categories</h6>
                <nav class="nav flex-column category-nav mt-3 border-start">
                    <a class="nav-link small-3 text-body-secondary rounded-4 py-1 <% if(!locals.query || !locals.query.category) { %>active<% } %>" href="/">All Posts</a>
                    <% if (typeof categories !== 'undefined' && categories.length) { %>
                        <% categories.forEach(category => { %>
                            <a class="nav-link small-3 text-body-secondary rounded-4 py-1 <% if(locals.query && locals.query.category === category.slug) { %>active<% } %>" href="?category=<%= category.slug %>">
                                <%= capitalizeEachWord(category.name) %>
                            </a>
                        <% }) %>
                    <% } %>
                </nav>
            </div>
        </div>

        <!-- Main content -->
        <div class="col-lg-7 px-lg-3">
            <main>
                <!-- Search -->
                <div class="search">
                    <h6><i class="bi bi-search"></i> Search</h6>
                    <form action="/" method="GET">
                        <input class="form-control" type="search" placeholder="keyword..." name="search" value="<%= locals.query ? query.search : '' %>" />
                    </form>
                </div>

                <div class="mt-5">
                    <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-3">
                        <h4 class="fs-5 fw-bold m-0"><%= title %></h4>
                        <div class="d-flex">
                            <div class="dropdown me-2 d-lg-none">
                                <button class="dropdown-toggle border-0 bg-light text-body-secondary small" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <%= (locals.query && locals.query.category) ? capitalizeEachWord(query.category) : 'All Posts' %>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end rounded-4 shadow border-0 p-1">
                                    <li><a class="dropdown-item text-body-secondary small py-1 <% if(!locals.query || !locals.query.category) { %>active<% } %>" href="/">All Posts</a></li>
                                    <% if (typeof categories !== 'undefined' && categories.length) { %>
                                        <% categories.forEach(category => { %>
                                            <li><a class="dropdown-item text-body-secondary small py-1 <% if(locals.query && locals.query.category === category.slug) { %>active<% } %>" href="?category=<%= category.slug %>"><%= capitalizeEachWord(category.name) %></a></li>
                                        <% }) %>
                                    <% } %>
                                </ul>
                            </div>
                            <div class="dropdown">
                                <button class="dropdown-toggle border-0 bg-light text-body-secondary small" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <%= query && query.order === 'asc' ? 'Oldest' : 'Latest' %>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end rounded-4 shadow border-0 p-1">
                                    <li><a class="dropdown-item text-body-secondary small py-1 <% if(!query?.order || query.order === 'desc') { %>active<% } %>" href="?<%= buildUrlParams(query, { order: 'desc', page: null }) %>">Latest</a></li>
                                    <li><a class="dropdown-item text-body-secondary small py-1 <% if(query?.order === 'asc') { %>active<% } %>" href="?<%= buildUrlParams(query, { order: 'asc', page: null }) %>">Oldest</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Posts -->
                    <% if (typeof posts !== 'undefined' && posts.length) { %>
                        <% posts.forEach(post => { %>
                            <div class="card rounded-4 mb-4 post">
                                <a href="/<%= post.slug %>" class="text-body-secondary text-decoration-none">
                                    <% if (post.thumbnail) { %>
                                        <img src="<%= post.thumbnail %>" class="card-img-top rounded-top-4" alt="<%= post.title %>" />
                                    <% } %>
                                    <div class="card-body px-3 px-md-4 pt-4 pb-3">
                                        <h5 class="card-title fw-semibold large-3 mb-2"><%= post.title %></h5>
                                        <div class="small-7 mb-2">
                                            <span><i class="bi bi-calendar3"></i> <%= new Date(post.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                                            <% if (post.category) { %>
                                                <span class="fw-bold mx-1">&centerdot;</span>
                                                <span><i class="bi bi-folder"></i> <%= post.category.name %></span>
                                            <% } %>
                                        </div>
                                        <p class="card-text small mb-0"><%= post.excerpt %></p>
                                        <% if (post.tags && post.tags.length) { %>
                                            <p class="card-text small mt-3 mb-0">
                                                <% post.tags.forEach(tag => { %>
                                                    <span class="badge bg-body-secondary text-body-secondary rounded-4 px-3 py-2 my-1">#<%= tag.name %></span>
                                                <% }) %>
                                            </p>
                                        <% } %>
                                    </div>
                                </a>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-5">
                            <h4 class="fs-5 fw-bold m-0">No posts found.</h4>
                            <p class="text-body-secondary small mt-2">Try adjusting your search or category filters.</p>
                        </div>
                    <% } %>

                    <!-- Pagination -->
                    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center mt-5">
                            <% if (currentPage > 1) { %>
                                <li class="page-item">
                                    <a class="page-link small rounded-start-4 text-body-secondary px-4 py-2" href="?<%= buildUrlParams(query, { page: currentPage - 1 }) %>">Previous</a>
                                </li>
                            <% } else { %>
                                 <li class="page-item">
                                    <a class="page-link small rounded-start-4 text-body-secondary px-4 py-2 disabled" href="#">Previous</a>
                                </li>
                            <% } %>

                             <% if (currentPage < totalPages) { %>
                                <li class="page-item">
                                    <a class="page-link small rounded-end-4 text-body-secondary px-4 py-2" href="?<%= buildUrlParams(query, { page: currentPage + 1 }) %>">Next</a>
                                </li>
                            <% } else { %>
                                <li class="page-item">
                                    <a class="page-link small rounded-end-4 text-body-secondary px-4 py-2 disabled" href="#">Next</a>
                                </li>
                            <% } %>
                        </ul>
                    </nav>
                    <% } %>
                </div>
            </main>
        </div>

        <hr class="d-lg-none my-5">

        <!-- Side widget 2-->
        <div class="col-lg-3">
            <div class="position-sticky" style="top: 2rem">
                <!-- Profile -->
                <h6 class="mt-lg-0"><i class="bi bi-person"></i> My Profile</h6>
                <div class="widget bg-white border text-center rounded-4 px-3 py-4">
                    <img src="<%= author.avatar %>" alt="<%= author.name %>" class="rounded-circle img-thumbnail mb-3 gper-img" />
                    <h6 class=""><%= author.name %></h6>
                    <p class="small text-body-secondary fst-italic m-0 px-4 px-md-5 px-lg-3">
                        <%= author.bio %>
                    </p>
                </div>

                <!-- Contact -->
                <h6 class="mt-5"><i class="bi bi-chat-text"></i> Contact Me</h6>
                <div class="widget bg-white border rounded-4 small pt-2 pb-1 px-2">
                    <div class="d-flex">
                        <a href="<%= author.socials.email %>" class="widget-link text-body-secondary text-decoration-none px-3 py-2 mb-1 w-100" target="_blank">
                            <i class="bi bi-envelope"></i>
                            <span class="ms-2">G-mail</span>
                        </a>
                    </div>
                    <div class="d-flex">
                        <a href="<%= author.socials.github %>" class="widget-link text-body-secondary text-decoration-none px-3 py-2 mb-1 w-100" target="_blank">
                            <i class="bi bi-github"></i>
                            <span class="ms-2">Github</span>
                        </a>
                    </div>
                    <div class="d-flex">
                        <a href="<%= author.socials.linkedin %>" class="widget-link text-body-secondary text-decoration-none px-3 py-2 mb-1 w-100" target="_blank">
                            <i class="bi bi-linkedin"></i>
                            <span class="ms-2">Linked-in</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
