<main class="content">
    <div class="container-fluid p-0">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3">Edit Post</h1>
            <a href="/dashboard/posts" class="btn btn-secondary">Back to Posts</a>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <form action="/dashboard/posts/<%= post._id %>?_method=PATCH&_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
                            <input type="hidden" name="existingThumbnail" value="<%= post.thumbnail %>">

                            <!-- Title -->
                            <div class="row mb-3">
                                <label for="title" class="col-sm-2 col-form-label">Title</label>
                                <div class="col-sm-10">
                                    <input type="text" class="form-control <%= errors.title ? 'is-invalid' : '' %>" id="title" name="title" value="<%= postData.title || post.title %>" required>
                                    <% if (errors.title) { %>
                                        <div class="invalid-feedback"><%= errors.title.msg %></div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Category -->
                            <div class="row mb-3">
                                <label for="category" class="col-sm-2 col-form-label">Category</label>
                                <div class="col-sm-10">
                                    <select class="form-select <%= errors.category ? 'is-invalid' : '' %>" id="category" name="category">
                                        <option value="">Select a category</option>
                                        <% postCategories.forEach(cat => { %>
                                            <option value="<%= cat %>" <%= (postData.category || post.category) === cat ? 'selected' : '' %>><%= capitalizeEachWord(cat) %></option>
                                        <% }) %>
                                    </select>
                                    <div class="form-text">Or create a new one below.</div>
                                    <% if (errors.category) { %>
                                        <div class="invalid-feedback"><%= errors.category.msg %></div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- New Category -->
                            <div class="row mb-3">
                                <label for="newCategory" class="col-sm-2 col-form-label">New Category</label>
                                <div class="col-sm-10">
                                    <input type="text" class="form-control <%= errors.newCategory ? 'is-invalid' : '' %>" id="newCategory" name="newCategory" value="<%= postData.newCategory || '' %>">
                                    <% if (errors.newCategory) { %>
                                        <div class="invalid-feedback"><%= errors.newCategory.msg %></div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Thumbnail -->
                            <div class="row mb-3">
                                <label for="thumbnail" class="col-sm-2 col-form-label">Thumbnail</label>
                                <div class="col-sm-10">
                                    <input class="form-control <%= errors.thumbnail ? 'is-invalid' : '' %>" type="file" id="thumbnail" name="thumbnail" onchange="previewImage(event)">
                                    <% if (errors.thumbnail) { %>
                                        <div class="invalid-feedback"><%= errors.thumbnail.msg %></div>
                                    <% } %>
                                    <% if (post.thumbnail) { %>
                                        <img id="image-preview" src="/<%= post.thumbnail %>" alt="Current Thumbnail" class="mt-2" style="max-width: 200px;"/>
                                        <div class="form-text">Current thumbnail is shown above. Upload a new one to replace it.</div>
                                    <% } else { %>
                                        <img id="image-preview" src="#" alt="Image Preview" class="mt-2" style="display: none; max-width: 200px;"/>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Tags -->
                            <div class="row mb-3">
                                <label for="tags" class="col-sm-2 col-form-label">Tags</label>
                                <div class="col-sm-10">
                                    <input type="text" class="form-control <%= errors.tags ? 'is-invalid' : '' %>" id="tags" name="tags" value="<%= postData.tags || post.tags.join(', ') %>">
                                    <div class="form-text">Comma-separated values (e.g., tech, news, gaming).</div>
                                    <% if (errors.tags) { %>
                                        <div class="invalid-feedback"><%= errors.tags.msg %></div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Excerpt -->
                            <div class="row mb-3">
                                <label for="excerpt" class="col-sm-2 col-form-label">Excerpt</label>
                                <div class="col-sm-10">
                                    <textarea class="form-control <%= errors.excerpt ? 'is-invalid' : '' %>" id="excerpt" name="excerpt" rows="3" data-char-count-target="excerpt-char-count"><%= postData.excerpt || post.excerpt %></textarea>
                                    <div id="excerpt-char-count" class="form-text text-end"></div>
                                    <% if (errors.excerpt) { %>
                                        <div class="invalid-feedback"><%= errors.excerpt.msg %></div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Content -->
                            <div class="row mb-3">
                                <label for="content" class="col-sm-2 col-form-label">Content</label>
                                <div class="col-sm-10">
                                    <textarea class="form-control <%= errors.content ? 'is-invalid' : '' %>" id="content" name="content" rows="10"><%= postData.content || post.content %></textarea>
                                    <% if (errors.content) { %>
                                        <div class="invalid-feedback"><%= errors.content.msg %></div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Status -->
                            <div class="row mb-3">
                                <label for="status" class="col-sm-2 col-form-label">Status</label>
                                <div class="col-sm-10">
                                    <select class="form-select <%= errors.status ? 'is-invalid' : '' %>" id="status" name="status">
                                        <option value="draft" <%= (postData.status || post.status) === 'draft' ? 'selected' : '' %>>Draft</option>
                                        <option value="published" <%= (postData.status || post.status) === 'published' ? 'selected' : '' %>>Published</option>
                                        <option value="archived" <%= (postData.status || post.status) === 'archived' ? 'selected' : '' %>>Archived</option>
                                    </select>
                                    <% if (errors.status) { %>
                                        <div class="invalid-feedback"><%= errors.status.msg %></div>
                                    <% } %>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-sm-10 offset-sm-2">
                                    <button type="submit" class="btn btn-primary">Update Post</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    function previewImage(event) {
        const reader = new FileReader();
        reader.onload = function(){
            const output = document.getElementById('image-preview');
            output.src = reader.result;
            output.style.display = 'block';
        };
        reader.readAsDataURL(event.target.files[0]);
    }

    document.addEventListener('DOMContentLoaded', function() {
        const textareas = document.querySelectorAll('textarea[data-char-count-target]');
        textareas.forEach(textarea => {
            const charCountEl = document.getElementById(textarea.dataset.charCountTarget);
            const maxLength = textarea.maxLength || 500; // Default to 500 if not set

            function updateCharCount() {
                const currentLength = textarea.value.length;
                charCountEl.textContent = `${currentLength} / ${maxLength}`;
            }

            textarea.addEventListener('input', updateCharCount);
            updateCharCount(); // Initial count
        });
    });
</script>
