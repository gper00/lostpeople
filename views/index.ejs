<div class="container mx-auto px-4 py-8 max-w-6xl">
    <div class="flex flex-col md:flex-row gap-8">

        <!-- Left sidebar - Categories -->
        <aside class="w-full md:w-2/12 md:block">
            <div class="sticky top-24">
                <h2 class="text-lg font-semibold font-display mb-3 flex items-center">
                    <i class="fa-solid fa-folder text-gray-500 mr-2"></i> Categories
                </h2>
                <nav class="pl-2 border-l border-gray-200">
                    <a href="/" class="block text-sm py-1.5 px-3 rounded-lg hover:bg-gray-100 <% if(!locals.query || !locals.query.category) { %>bg-primary-50 text-primary-600 font-medium<% } else { %>text-gray-600<% } %>">
                        All Posts
                    </a>
                    <% if (typeof categories !== 'undefined' && categories.length) { %>
                        <% categories.forEach(category => { %>
                            <a href="?category=<%= category.slug %>" class="block text-sm py-1.5 px-3 rounded-lg hover:bg-gray-100 <% if(locals.query && locals.query.category === category.slug) { %>bg-primary-50 text-primary-600 font-medium<% } else { %>text-gray-600<% } %>">
                                <%= category.name %>
                            </a>
                        <% }) %>
                    <% } %>
                </nav>
            </div>
        </aside>

        <!-- Main content -->
        <main class="w-full md:w-7/12 order-2 md:order-1">
            <!-- Search -->
            <div class="mb-8">
                <form action="/" method="GET">
                    <div class="relative">
                        <input
                            type="search"
                            name="search"
                            placeholder="Search for posts..."
                            value="<%= locals.query ? query.search : '' %>"
                            class="w-full p-3 pl-10 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition"
                        >
                        <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    </div>
                </form>
            </div>

            <!-- Header -->
            <div class="flex items-center justify-between border-b border-gray-200 pb-4 mb-6">
                <h1 class="text-xl font-bold font-display"><%= title %></h1>
                <div class="flex items-center space-x-2">
                    <!-- View Toggle -->
                    <div class="flex rounded-lg overflow-hidden border border-gray-200">
                        <button id="gridViewBtn" type="button" class="flex items-center justify-center text-xs p-2 w-8 bg-primary-500 text-white">
                            <i class="fa-solid fa-grip"></i>
                        </button>
                        <button id="listViewBtn" type="button" class="flex items-center justify-center text-xs p-2 w-8 bg-white text-gray-500 hover:bg-gray-100">
                            <i class="fa-solid fa-list"></i>
                        </button>
                    </div>
                    <!-- Sort Dropdown -->
                    <div class="relative">
                        <button id="sortDropdown" type="button" class="flex items-center text-sm text-gray-600 hover:text-gray-900 bg-white px-3 py-2 rounded-lg border border-gray-200">
                            <span class="capitalize"><%= query && query.order === 'asc' ? 'Oldest' : 'Latest' %></span>
                            <i class="fa-solid fa-chevron-down ml-2 text-xs"></i>
                        </button>
                        <div id="sortMenu" class="hidden absolute right-0 mt-2 py-2 w-32 bg-white rounded-xl shadow-lg border border-gray-100 z-10">
                            <a href="?<%= buildUrlParams(query, { order: 'desc', page: null }) %>" class="block px-4 py-2 text-sm <%= !query?.order || query.order === 'desc' ? 'bg-primary-50 text-primary-700' : 'text-gray-700 hover:bg-gray-100' %>">Latest</a>
                            <a href="?<%= buildUrlParams(query, { order: 'asc', page: null }) %>" class="block px-4 py-2 text-sm <%= query?.order === 'asc' ? 'bg-primary-50 text-primary-700' : 'text-gray-700 hover:bg-gray-100' %>">Oldest</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Posts Grid View -->
            <% if (typeof posts !== 'undefined' && posts.length) { %>
                <div id="gridView" class="grid grid-cols-1 gap-6">
                    <% posts.forEach(post => { %>
                        <article class="bg-white rounded-2xl shadow-sm hover:shadow-md card-transition overflow-hidden border border-gray-100">
                            <% if (post.thumbnail) { %>
                            <a href="/<%= post.slug %>" class="block">
                                <img src="<%= post.thumbnail || post.coverImage || '/img/no-image.png' %>" alt="<%= post.title %>" class="w-full h-48 object-cover">
                            </a>
                            <% } %>
                            <div class="p-5">
                                <% if (post.category) { %>
                                <a href="?category=<%= post.category.slug %>" class="text-xs font-medium text-primary-600 uppercase"><%= post.category.name %></a>
                                <% } %>
                                <h3 class="text-lg font-bold font-display mt-2 mb-2">
                                    <a href="/<%= post.slug %>" class="hover:text-primary-600 transition"><%= post.title %></a>
                                </h3>
                                <p class="text-sm text-gray-500 mb-4"><%= post.excerpt %></p>
                                <div class="flex items-center text-xs text-gray-500">
<img src="<%= (post.user && post.user.image) ? post.user.image : '/assets/img/user-default.jpg' %>" alt="<%= (post.user && post.user.name) ? post.user.name : 'Anonymous' %>" class="w-8 h-8 rounded-full mr-2 object-cover">
                                    <span><%= post.author.name %> &bull; <%= new Date(post.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                </div>

                <!-- Posts List View -->
                <div id="listView" class="space-y-6 hidden">
                    <% posts.forEach(post => { %>
                        <article class="bg-white rounded-2xl shadow-sm hover:shadow-md card-transition overflow-hidden border border-gray-100 flex flex-col sm:flex-row">
                            <a href="/<%= post.slug %>" class="block sm:w-2/5">
                                <img src="<%= post.thumbnail || post.coverImage || '/img/no-image.png' %>" alt="<%= post.title %>" class="w-full h-48 sm:h-full object-cover">
                            </a>
                            <div class="p-5 flex-1">
                                <% if (post.category) { %>
                                <a href="?category=<%= post.category.slug %>" class="text-xs font-medium text-primary-600 uppercase"><%= post.category.name %></a>
                                <% } %>
                                <h3 class="text-lg font-bold font-display mt-2 mb-2">
                                    <a href="/<%= post.slug %>" class="hover:text-primary-600 transition"><%= post.title %></a>
                                </h3>
                                <p class="text-sm text-gray-500 mb-4 line-clamp-3"><%= post.excerpt %></p>
                                <div class="flex items-center text-xs text-gray-500">
                                    <img src="<%= post.author.avatar || '/img/default-avatar.png' %>" alt="<%= post.author.name %>" class="w-8 h-8 rounded-full mr-2 object-cover">
                                    <span><%= post.author.name %> &bull; <%= new Date(post.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                </div>

            <% } else { %>
                 <!-- No Posts Found -->
                <div class="text-center py-16">
                    <i class="fa-solid fa-ghost text-4xl text-gray-300"></i>
                    <h2 class="mt-4 text-xl font-semibold text-gray-600">No Posts Found</h2>
                    <p class="mt-2 text-gray-500">Try adjusting your search or category filters.</p>
                    <a href="/" class="mt-4 inline-block px-5 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition">Clear Filters</a>
                </div>
            <% } %>

            <!-- Pagination -->
            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                <nav class="mt-12 flex justify-center">
                    <ul class="flex items-center -space-x-px h-10 text-base">
                        <% if (currentPage > 1) { %>
                            <li>
                                <a href="?page=<%= currentPage - 1 %>&<%= new URLSearchParams(query || {}).toString() %>" class="flex items-center justify-center px-4 h-10 ms-0 leading-tight text-gray-500 bg-white border border-e-0 border-gray-300 rounded-s-lg hover:bg-gray-100 hover:text-gray-700">
                                    <span class="sr-only">Previous</span>
                                    <i class="fa-solid fa-chevron-left w-3 h-3"></i>
                                </a>
                            </li>
                        <% } %>
                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li>
                                <a href="?page=<%= i %>&<%= new URLSearchParams(query || {}).toString() %>" class="flex items-center justify-center px-4 h-10 leading-tight <%= i === currentPage ? 'text-primary-600 border border-primary-300 bg-primary-50 hover:bg-primary-100 hover:text-primary-700' : 'text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-700' %>"><%= i %></a>
                            </li>
                        <% } %>
                        <% if (currentPage < totalPages) { %>
                            <li>
                                <a href="?page=<%= currentPage + 1 %>&<%= new URLSearchParams(query || {}).toString() %>" class="flex items-center justify-center px-4 h-10 leading-tight text-gray-500 bg-white border border-gray-300 rounded-e-lg hover:bg-gray-100 hover:text-gray-700">
                                    <span class="sr-only">Next</span>
                                    <i class="fa-solid fa-chevron-right w-3 h-3"></i>
                                </a>
                            </li>
                        <% } %>
                    </ul>
                </nav>
            <% } %>

        </main>

        <!-- Right sidebar - Popular posts -->
        <aside class="w-full md:w-3/12 order-1 md:order-2">
            <div class="sticky top-24">
                <!-- Profile -->
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-center mb-8">
                    <img
                        src="https://dummyimage.com/200x200/000/fff"
                        alt="John Doe"
                        class="w-24 h-24 rounded-full mx-auto mb-4 object-cover border-4 border-white shadow"
                    >
                    <h2 class="text-lg font-bold font-display mb-1">John Doe</h2>
                    <p class="text-gray-500 text-sm italic mb-4">Web Developer & Designer</p>

                    <div class="flex justify-center space-x-3">
                        <a href="#" class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition">
                            <i class="fab fa-twitter"></i>
                        </a>
                        <a href="#" class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition">
                            <i class="fab fa-github"></i>
                        </a>
                        <a href="#" class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                    </div>
                </div>

                <div class="bg-primary-600 text-white p-5 rounded-2xl mb-8">
                    <h2 class="text-lg font-semibold font-display mb-3">Subscribe to Newsletter</h2>
                    <p class="text-sm text-primary-100 mb-4">Get the latest posts delivered straight to your inbox.</p>
                    <form>
                        <input
                            type="email"
                            placeholder="Your email address"
                            class="w-full bg-white/10 border border-white/20 text-white placeholder-white/60 p-3 rounded-lg mb-3 text-sm focus:outline-none focus:ring-2 focus:ring-white/50"
                        >
                        <button type="submit" class="w-full bg-white text-primary-600 font-medium py-2 px-4 rounded-lg hover:bg-white/90 transition">
                            Subscribe
                        </button>
                    </form>
                </div>

                <% if (typeof popularPosts !== 'undefined' && popularPosts.length) { %>
                    <h2 class="text-lg font-semibold font-display mb-3 flex items-center">
                        <i class="fa-solid fa-star text-gray-500 mr-2"></i> Popular Posts
                    </h2>
                    <div class="space-y-4">
                        <% popularPosts.forEach(post => { %>
                            <div class="flex items-start space-x-3">
                                <!-- <img src="<%= post.thumbnail || post.coverImage || '/img/no-image.png' %>" alt="<%= post.title %>" class="w-16 h-16 object-cover rounded-lg"> -->
                                <img src="https://dummyimage.com/600x400/000/fff" alt="<%= post.title %>" class="w-16 h-16 object-cover rounded-lg">
                                <div>
                                    <h4 class="text-sm font-bold font-display">
                                        <a href="/<%= post.slug %>" class="hover:text-primary-600 transition"><%= post.title %></a>
                                    </h4>
                                    <span class="text-xs text-gray-500"><%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </aside>

    </div>
</div>
