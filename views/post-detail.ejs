<div class="container mx-auto px-4 py-8 max-w-6xl">
    <div class="flex flex-col md:flex-row gap-8">

        <aside class="w-full md:w-1/5">
        </aside>
        <!-- Main content -->
        <main class="w-full md:w-3/5 order-2 md:order-1">
            <!-- Breadcrumb -->
            <nav class="mb-6 text-sm text-gray-500">
                <ol class="list-none p-0 inline-flex">
                    <li class="flex items-center">
                        <a href="/" class="text-primary-600 hover:text-primary-700">Home</a>
                        <i class="fa-solid fa-chevron-right mx-2 text-xs"></i>
                    </li>
                    <li class="flex items-center">
                        <span class="text-gray-500"><%= post.title %></span>
                    </li>
                </ol>
            </nav>

            <!-- Article Header -->
            <div class="mb-8">
                <h1 class="text-3xl md:text-4xl font-bold font-display mb-4 text-gray-900"><%= post.title %></h1>

                <div class="flex flex-wrap items-center text-sm text-gray-500 mb-4">
                    <div class="flex items-center mr-6 mb-2 md:mb-0">
                        <img src="<%= post.userId.image || '/assets/img/user-default.jpg' %>" alt="Author" class="w-6 h-6 rounded-full mr-2">
                        <span><%= post.userId.fullname %></span>
                    </div>
                    <div class="flex items-center mr-6 mb-2 md:mb-0">
                        <i class="fa-regular fa-calendar mr-1"></i>
                        <span><%= formatDate(post.createdAt) %></span>
                    </div>
                    <!-- <div class="flex items-center mr-6 mb-2 md:mb-0">
                        <i class="fa-regular fa-clock mr-1"></i>
                        <span>8 min read</span>
                    </div> -->
                    <% if (post.category && post.category.name) { %>
                    <div class="flex items-center">
                        <i class="fa-solid fa-folder mr-1"></i>
                        <span><%= capitalizeEachWord(post.category.name) %></span>
                    </div>
                    <% } %>
                </div>

                <% if (post.tags.length) { %>
                <div class="flex flex-wrap gap-2 mb-6">
                    <% (typeof post.tags === 'string' ? post.tags.split(',').map(t => t.trim()) : post.tags).forEach(tag => { %>
                        <span class="px-3 py-1 bg-gray-100 text-gray-600 text-xs rounded-full">#<%= tag.name %></span>
                    <% }) %>
                </div>
                <% } %>

                <% if(post.thumbnail) { %>
                <div class="relative rounded-xl overflow-hidden mb-8">
                    <img src="<%= post.thumbnail || '/assets/img/no-image.jpg' %>" alt="<%= post.title %>" class="w-full h-auto object-cover">
                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
                        <p class="text-white text-sm"><%= post.title %></p>
                    </div>
                </div>
                <% } %>
            </div>

            <!-- Article Content -->
            <article class="bg-white rounded-2xl shadow-sm p-6 md:p-8 mb-8 markdown-body article-content prose">
                <%- post.content %>
            </article>

            <!-- Author Bio -->
            <div class="bg-white rounded-2xl shadow-sm p-6 mb-8">
                <div class="flex items-start">
                    <img src="https://dummyimage.com/80x80/000/fff" alt="John Doe" class="w-16 h-16 rounded-full mr-4">
                    <div>
                        <h3 class="text-lg font-bold font-display mb-1">John Doe</h3>
                        <p class="text-gray-600 text-sm mb-3">Senior Web Developer with 8+ years of experience. Passionate about JavaScript, React, and web performance optimization.</p>
                        <div class="flex space-x-3">
                            <a href="#" class="text-gray-500 hover:text-primary-600">
                                <i class="fab fa-twitter"></i>
                            </a>
                            <a href="#" class="text-gray-500 hover:text-primary-600">
                                <i class="fab fa-github"></i>
                            </a>
                            <a href="#" class="text-gray-500 hover:text-primary-600">
                                <i class="fab fa-linkedin-in"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comments Section -->
            <div class="bg-white rounded-2xl shadow-sm p-6 mb-8">
                <h3 class="text-xl font-bold font-display mb-6">Comments (3)</h3>

                <!-- Comment 1 -->
                <div class="flex mb-6 pb-6 border-b border-gray-100">
                    <img src="https://dummyimage.com/48x48/ccc/fff" alt="Sarah Johnson" class="w-12 h-12 rounded-full mr-4">
                    <div class="flex-1">
                        <div class="flex justify-between items-start mb-2">
                            <div>
                                <h4 class="font-bold">Sarah Johnson</h4>
                                <span class="text-gray-500 text-sm">April 2, 2023</span>
                            </div>
                            <button class="text-gray-400 hover:text-primary-600">
                                <i class="fa-solid fa-reply"></i>
                            </button>
                        </div>
                        <p class="text-gray-700 mb-3">Great introduction! The examples really helped me understand the concepts. Could you do a follow-up on JavaScript frameworks?</p>
                        <div class="flex items-center text-sm text-gray-500">
                            <button class="flex items-center mr-4 hover:text-primary-600">
                                <i class="fa-regular fa-thumbs-up mr-1"></i> 12
                            </button>
                            <button class="flex items-center hover:text-primary-600">
                                <i class="fa-regular fa-thumbs-down mr-1"></i> 2
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Comment 2 -->
                <div class="flex mb-6 pb-6 border-b border-gray-100">
                    <img src="https://dummyimage.com/48x48/ccc/fff" alt="Mike Chen" class="w-12 h-12 rounded-full mr-4">
                    <div class="flex-1">
                        <div class="flex justify-between items-start mb-2">
                            <div>
                                <h4 class="font-bold">Mike Chen</h4>
                                <span class="text-gray-500 text-sm">March 28, 2023</span>
                            </div>
                            <button class="text-gray-400 hover:text-primary-600">
                                <i class="fa-solid fa-reply"></i>
                            </button>
                        </div>
                        <p class="text-gray-700 mb-3">Thanks for the clear explanations. The section on modern JavaScript features was especially helpful!</p>
                        <div class="flex items-center text-sm text-gray-500">
                            <button class="flex items-center mr-4 hover:text-primary-600">
                                <i class="fa-regular fa-thumbs-up mr-1"></i> 8
                            </button>
                            <button class="flex items-center hover:text-primary-600">
                                <i class="fa-regular fa-thumbs-down mr-1"></i> 0
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Comment 3 -->
                <div class="flex">
                    <img src="https://dummyimage.com/48x48/ccc/fff" alt="Alex Rivera" class="w-12 h-12 rounded-full mr-4">
                    <div class="flex-1">
                        <div class="flex justify-between items-start mb-2">
                            <div>
                                <h4 class="font-bold">Alex Rivera</h4>
                                <span class="text-gray-500 text-sm">March 20, 2023</span>
                            </div>
                            <button class="text-gray-400 hover:text-primary-600">
                                <i class="fa-solid fa-reply"></i>
                            </button>
                        </div>
                        <p class="text-gray-700 mb-3">Excellent article for beginners. The table of data types was particularly useful.</p>
                        <div class="flex items-center text-sm text-gray-500">
                            <button class="flex items-center mr-4 hover:text-primary-600">
                                <i class="fa-regular fa-thumbs-up mr-1"></i> 15
                            </button>
                            <button class="flex items-center hover:text-primary-600">
                                <i class="fa-regular fa-thumbs-down mr-1"></i> 1
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Add Comment Form -->
            <div class="bg-white rounded-2xl shadow-sm p-6 mb-8">
                <h3 class="text-xl font-bold font-display mb-6">Leave a Comment</h3>
                <form>
                    <div class="mb-4">
                        <label for="comment" class="block text-gray-700 text-sm font-medium mb-2">Your Comment</label>
                        <textarea id="comment" rows="4" class="w-full px-3 py-2 text-gray-700 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Share your thoughts..."></textarea>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <div>
                            <label for="name" class="block text-gray-700 text-sm font-medium mb-2">Name</label>
                            <input type="text" id="name" class="w-full px-3 py-2 text-gray-700 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Your name">
                        </div>
                        <div>
                            <label for="email" class="block text-gray-700 text-sm font-medium mb-2">Email</label>
                            <input type="email" id="email" class="w-full px-3 py-2 text-gray-700 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="your@email.com">
                        </div>
                    </div>
                    <div class="flex items-center mb-4">
                        <input id="remember" type="checkbox" class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded">
                        <label for="remember" class="ml-2 block text-sm text-gray-700">
                            Save my name and email for the next time I comment
                        </label>
                    </div>
                    <button type="submit" class="bg-primary-500 hover:bg-primary-600 text-white font-medium py-2 px-6 rounded-lg transition duration-200">
                        Post Comment
                    </button>
                </form>
            </div>

            <!-- Related Posts -->
            <div class="mb-8">
                <h3 class="text-xl font-bold font-display mb-6">Related Posts</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Related Post 1 -->
                    <a href="/css-grid-layout" class="block">
                        <article class="bg-white rounded-2xl shadow-sm hover:shadow-md card-transition overflow-hidden border border-gray-100">
                            <div class="p-5">
                                <h4 class="text-lg font-bold font-display mb-2 text-gray-900">Mastering CSS Grid Layout</h4>
                                <div class="flex items-center text-xs text-gray-500 mb-3">
                                    <span class="flex items-center">
                                        <i class="fa-regular fa-calendar mr-1"></i>
                                        Feb 28, 2023
                                    </span>
                                    <span class="mx-2">•</span>
                                    <span class="flex items-center">
                                        <i class="fa-solid fa-folder mr-1"></i>
                                        Design
                                    </span>
                                </div>
                                <p class="text-gray-600 text-sm">A comprehensive guide to CSS Grid Layout, covering all the properties and techniques you need to create modern web layouts.</p>
                            </div>
                        </article>
                    </a>

                    <!-- Related Post 2 -->
                    <a href="/nodejs-express-tutorial" class="block">
                        <article class="bg-white rounded-2xl shadow-sm hover:shadow-md card-transition overflow-hidden border border-gray-100">
                            <div class="p-5">
                                <h4 class="text-lg font-bold font-display mb-2 text-gray-900">Building APIs with Node.js and Express</h4>
                                <div class="flex items-center text-xs text-gray-500 mb-3">
                                    <span class="flex items-center">
                                        <i class="fa-regular fa-calendar mr-1"></i>
                                        Jan 10, 2023
                                    </span>
                                    <span class="mx-2">•</span>
                                    <span class="flex items-center">
                                        <i class="fa-solid fa-folder mr-1"></i>
                                        Programming
                                    </span>
                                </div>
                                <p class="text-gray-600 text-sm">Step-by-step tutorial on creating RESTful APIs using Node.js and Express framework. Learn routing, middleware, and database integration.</p>
                            </div>
                        </article>
                    </a>
                </div>
            </div>

            <!-- Navigation -->
            <div class="flex justify-between">
                <a href="/previous-post" class="flex items-center text-primary-600 hover:text-primary-700 font-medium">
                    <i class="fa-solid fa-arrow-left mr-2"></i>
                    Previous Post
                </a>
                <a href="/next-post" class="flex items-center text-primary-600 hover:text-primary-700 font-medium">
                    Next Post
                    <i class="fa-solid fa-arrow-right ml-2"></i>
                </a>
            </div>
        </main>

        <!-- Right sidebar -->
        <aside class="w-full md:w-1/5 order-1 md:order-2">
            <div class="sticky top-24">
                <h2 class="text-lg font-semibold font-display mb-3 flex items-center">
                    On This Page
                </h2>
                <ul id="toc" class="pl-2 border-l border-gray-200 space-y-1"></ul>
            </div>
        </aside>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const toc = document.getElementById('toc');
        const headings = document.querySelectorAll('.article-content h2, .article-content h3');

        if (headings.length === 0) {
            toc.innerHTML = "<li class='text-sm text-gray-400'>Tidak ada bagian cukup dalam artikel ini</li>";
            return;
        }

        headings.forEach((heading) => {
            if (!heading.id) heading.id = `section-${Date.now()}-${Math.round(Math.random() * 1000)}`;

            const link = document.createElement('a');
            link.href = `#${heading.id}`;
            link.textContent = heading.textContent;
            link.className = "block py-1 px-3 text-sm text-gray-600 hover:bg-gray-50 rounded-md no-underline hover:text-primary-600 transition";

            const item = document.createElement('li');
            item.appendChild(link);

            toc.appendChild(item);
        });
    });
</script>

<style>
    .article-content h2 {
      scroll-margin-top: 6rem; /* biar tidak tertutup oleh navbar ketika scroll automatis */
    }
</style>
